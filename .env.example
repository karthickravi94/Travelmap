# Database - SQLite (local) or PostgreSQL (free tier like Neon/Supabase)
DATABASE_URL="file:./dev.db"
# For PostgreSQL: DATABASE_URL="postgresql://user:password@host:5432/travelmap"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Optional: GitHub OAuth (free)
GITHUB_ID=""
GITHUB_SECRET=""

# Optional: Google OAuth (free)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Upload directory (local storage)
UPLOAD_DIR="public/uploads"
MAX_FILE_SIZE="10485760"
